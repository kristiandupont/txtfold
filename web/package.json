    "typescript": "~5.9.3",
    "vite": "^8.0.1"
  },
  "dependencies": {
    "@b9g/crank": "^0.7.8",
    "@tailwindcss/vite": "^4.2.2",
    "marked": "^17.0.5",
    "tailwindcss": "^4.2.2"
  }

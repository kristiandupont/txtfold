{
  "name": "txtfold",
  "version": "0.1.0",
  "description": "Identifies patterns and outliers in large log files and structured data",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "browser": "./dist/browser.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist/",
    "wasm/",
    "wasm-web/"
  ],
  "scripts": {
    "build:wasm": "wasm-pack build ../../core --out-dir ../bindings/npm/wasm --out-name txtfold --target nodejs --no-pack --features wasm",
    "build:wasm-web": "wasm-pack build ../../core --out-dir ../bindings/npm/wasm-web --out-name txtfold --target web --no-pack --features wasm",
    "build:ts": "tsc",
    "gen-types": "bun ../../tools/gen-types.ts",
    "build": "bun run build:wasm && bun run build:wasm-web && bun run build:ts"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/kristiandupont/txtfold"
  },
  "keywords": ["logs", "analysis", "patterns", "summarization"],
  "license": "MIT OR Apache-2.0",
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^5.0"
  }
}
